# Panorama NAT Audit - Configuration
# Copy this to .env and adjust values

# Web app login credentials
APP_USER=admin
APP_PASS=admin

# Flask secret key (generate a random one for production)
SECRET_KEY=replace-with-a-random-secret-key

# Panorama connection (pre-fills the connect form)
PANORAMA_HOST=panorama.example.com
PANORAMA_USER=admin
PANORAMA_PASS=changeme!
# PANORAMA_API_KEY=
PANORAMA_METHOD=api

# Set to true to auto-connect on page load (skips clicking "Connect")
AUTO_CONNECT=false
